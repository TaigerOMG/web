        "\u0412 \u043E\u0431\u044A\u044F\u0432\u043B\u0435\u043D\u0438\u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430 \u003Cstrong\u003E\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F \u0432\u0438\u043B\u043B\u0430 \u043D\u043E\u0432\u043E\u0439 \u043F\u043E\u0441\u0442\u0440\u043E\u0439\u043A\u0438\u003C/strong\u003E \u043F\u043B\u043E\u0449\u0430\u0434\u044C\u044E \u003Cstrong\u003E189 \u043C\u00B2\u003C/strong\u003E, \u003Cstrong\u003E\u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u0430\u044F\u003C/strong\u003E \u043D\u0430 \u0443\u0447\u0430\u0441\u0442\u043A\u0435 \u043F\u043B\u043E\u0449\u0430\u0434\u044C\u044E \u003Cstrong\u003E405 \u043C\u00B2\u003C/strong\u003E, \u043E\u0442\u043B\u0438\u0447\u0430\u044E\u0449\u0430\u044F\u0441\u044F \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u043D\u043E\u0441\u0442\u044C\u044E, \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u043B\u0435\u0441\u043E\u043F\u0430\u0440\u043A\u043E\u043C \u0438 \u0431\u043B\u0438\u0437\u043E\u0441\u0442\u044C\u044E \u043A \u043C\u0435\u0441\u0442\u043D\u044B\u043C \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u043C \u0438\u043D\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B.",
        "\u0412 \u0434\u043E\u043C\u0435 \u0438\u043C\u0435\u044E\u0442\u0441\u044F \u003Cstrong\u003E3 \u0434\u0432\u0443\u0445\u043C\u0435\u0441\u0442\u043D\u044B\u0435 \u0441\u043F\u0430\u043B\u044C\u043D\u0438\u003C/strong\u003E, \u0447\u0430\u0441\u0442\u043D\u044B\u0439 \u0433\u0430\u0440\u0430\u0436 \u0441 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043D\u0438\u044F, \u0432\u0435\u0440\u0430\u043D\u0434\u044B \u0441 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0441\u043A\u043E\u043B\u044C\u0437\u044F\u0449\u0438\u043C \u043A\u0435\u0440\u0430\u043C\u043E\u0433\u0440\u0430\u043D\u0438\u0442\u043E\u043C, \u0444\u0430\u0441\u0430\u0434 \u0438\u0437 \u0431\u0435\u043B\u043E\u0433\u043E \u0440\u0430\u0441\u0442\u0432\u043E\u0440\u0430, \u043E\u043A\u043D\u0430 Technal \u0441 \u0442\u0435\u0440\u043C\u043E\u0440\u0430\u0437\u0440\u044B\u0432\u043E\u043C \u0438 \u0441\u0442\u0435\u043A\u043B\u043E \u0441 \u043D\u0438\u0437\u043A\u0438\u043C \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u043E\u043C \u0438\u0437\u043B\u0443\u0447\u0435\u043D\u0438\u044F.",
        "\u041F\u0440\u043E\u0435\u043A\u0442 \u043F\u0440\u0435\u0434\u0443\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0430\u044D\u0440\u043E\u0442\u0435\u0440\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u043E\u0442\u043E\u043F\u043B\u0435\u043D\u0438\u044F Panasonic, \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043A\u043E\u043D\u0434\u0438\u0446\u0438\u043E\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F \u0441 \u0432\u043E\u0437\u0434\u0443\u0445\u043E\u0432\u043E\u0434\u0430\u043C\u0438 \u043D\u0430 \u043A\u0430\u0436\u0434\u043E\u043C \u044D\u0442\u0430\u0436\u0435, \u0436\u0430\u043B\u044E\u0437\u0438 \u0441 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043F\u0440\u0438\u0432\u043E\u0434\u043E\u043C, \u0440\u0435\u0437\u0435\u0440\u0432\u0443\u0430\u0440 \u0434\u043B\u044F \u0441\u0442\u043E\u0447\u043D\u044B\u0445 \u0432\u043E\u0434 \u043E\u0431\u044A\u0435\u043C\u043E\u043C \u003Cstrong\u003E1 245 \u043B\u003C/strong\u003E \u0438 \u0440\u0435\u0437\u0435\u0440\u0432\u0443\u0430\u0440 \u0434\u043B\u044F \u0434\u043E\u0436\u0434\u0435\u0432\u043E\u0439 \u0432\u043E\u0434\u044B \u043E\u0431\u044A\u0435\u043C\u043E\u043C \u003Cstrong\u003E3 000 \u043B\u003C/strong\u003E, \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u044B\u0435 \u0434\u043B\u044F \u043F\u043E\u043B\u0438\u0432\u0430 \u0438 \u0441\u0430\u043D\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043D\u0443\u0436\u0434.",
        "\u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438 \u0432 \u043E\u0431\u044A\u044F\u0432\u043B\u0435\u043D\u0438\u0438, \u043F\u0440\u0438 \u0441\u0432\u043E\u0435\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C \u043E\u0444\u043E\u0440\u043C\u043B\u0435\u043D\u0438\u0438 \u043F\u043E\u043A\u0443\u043F\u043A\u0438 \u0435\u0449\u0451 \u043C\u043E\u0436\u043D\u043E \u0432\u044B\u0431\u0440\u0430\u0442\u044C \u0438\u043D\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043B\u044C\u043D\u0443\u044E \u043E\u0442\u0434\u0435\u043B\u043A\u0443. \u041F\u0440\u043E\u0432\u0435\u0440\u044C\u0442\u0435 \u0437\u0434\u0435\u0441\u044C \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0442\u0435\u043A\u0441\u0442, \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F, PDF-\u0444\u0430\u0439\u043B \u0438 \u043F\u043B\u0430\u043D \u0443\u0447\u0430\u0441\u0442\u043A\u0430 \u043F\u0435\u0440\u0435\u0434 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0435\u0439."
      ],
      "location_text": "Mas Moreu \u00B7 Torroella de Montgr\u00ED \u00B7 Girona"
    }
  }
}